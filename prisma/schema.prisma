generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  password           String
  avatar             String?
  role               String   @default("reader") // reader, author, publisher, bookstore
  preferredLanguages String   @default("english") // comma-separated: sinhala,english,tamil
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  bookshelves     Bookshelf[]
  comments        Comment[]
  pageRequests    PageRequest[]
  addedBooks      Book[]       @relation("BookAdder")
  editSuggests    BookEdit[]
  claimedBooks    Book[]       @relation("BookClaimer")
  uploadedPreviews PagePreview[]
}

model Category {
  id        String @id @default(cuid())
  name      String @unique
  nameSi    String? // Sinhala
  nameTa    String? // Tamil
  icon      String
  slug      String @unique
  bookCount Int    @default(0)

  books Book[]
}

model Book {
  id             String   @id @default(cuid())
  title          String
  titleSi        String? // Sinhala title
  titleTa        String? // Tamil title
  author         String
  publisher      String?
  isbn           String?
  language       String   @default("english") // sinhala, english, tamil
  year           Int?
  pageCount      Int?
  description    String?
  coverImage     String?
  categoryId     String?
  status         String   @default("community") // community, verified
  addedById      String
  claimedById    String?
  likes          Int      @default(0)
  readingCount   Int      @default(0)
  listeningCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category        Category?    @relation(fields: [categoryId], references: [id])
  addedBy         User         @relation("BookAdder", fields: [addedById], references: [id])
  claimedBy       User?        @relation("BookClaimer", fields: [claimedById], references: [id])
  bookshelves     Bookshelf[]
  comments        Comment[]
  pagePreviews    PagePreview[]
  pageRequests    PageRequest[]
  edits           BookEdit[]
}

model Bookshelf {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  status    String   @default("want_to_read") // want_to_read, currently_reading, finished
  addedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  bookId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model PagePreview {
  id           String   @id @default(cuid())
  bookId       String
  pageNumber   Int
  content      String // text content of the preview page
  uploadedById String
  createdAt    DateTime @default(now())

  book      Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
}

model PageRequest {
  id        String   @id @default(cuid())
  bookId    String
  userId    String
  chapter   String?
  pages     String? // e.g. "45-50"
  reason    String?
  status    String   @default("pending") // pending, fulfilled, declined
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model BookEdit {
  id        String   @id @default(cuid())
  bookId    String
  userId    String
  field     String
  oldValue  String?
  newValue  String
  status    String   @default("pending") // pending, approved, rejected
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}